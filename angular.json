name: Deploy Angular to EC2 (Nginx)

on:
  push:
    branches:
      - main

jobs:
  deploy:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout code
        uses: actions/checkout@v3

      - name: Setup Node
        uses: actions/setup-node@v3
        with:
          node-version: 24

      - name: Install dependencies
        run: npm install

      - name: Build Angular app
        run: npm run build -- --configuration production

      - name: Check build output
        run: ls -R dist

      # ✅ FIXED SCP (no *)
      - name: Copy build to EC2
        uses: appleboy/scp-action@v0.1.4
        with:
          host: ${{ secrets.EC2_HOST }}
          username: ${{ secrets.EC2_USER }}
          key: ${{ secrets.EC2_SSH_KEY }}
          source: "dist/ec2-cicd-app/browser"
          target: "/home/ubuntu"

      - name: Deploy to Nginx
        uses: appleboy/ssh-action@v1.0.0
        with:
          host: ${{ secrets.EC2_HOST }}
          username: ${{ secrets.EC2_USER }}
          key: ${{ secrets.EC2_SSH_KEY }}
          script: |
            sudo rm -rf /var/www/angular-app/*
            sudo mkdir -p /var/www/angular-app

            sudo cp -r /home/ubuntu/dist/ec2-cicd-app/browser/* /var/www/angular-app/

            sudo chown -R wwww/angular-app
            sudo systemctl restart nginx